# ======================
# POSTGRES (DATA - FLINK)
# ======================
POSTGRES_DB=postgres_crypto
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ======================
# POSTGRES (AIRFLOW META)
# ======================
AIRFLOW_DB_NAME=airflow_meta
AIRFLOW_DB_USER=postgres
AIRFLOW_DB_PASSWORD=postgres
AIRFLOW_DB_HOST=postgres_airflow
AIRFLOW_DB_PORT=5432

# ======================
# AIRFLOW CONNECTION
# ======================
AIRFLOW_DB_URL=postgresql+psycopg2://${AIRFLOW_DB_USER}:${AIRFLOW_DB_PASSWORD}@${AIRFLOW_DB_HOST}:${AIRFLOW_DB_PORT}/${AIRFLOW_DB_NAME}


AIRFLOW_IMAGE_NAME=apache/airflow:3.1.8
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

AIRFLOW__API_AUTH__JWT_SECRET=airflow_jwt_secret
AIRFLOW__API_AUTH__JWT_ISSUER=airflow

# ======================
# KAFKA / REDPANDA
# ======================
KAFKA_BROKER=redpanda:29092
KAFKA_TOPIC=raw_trade